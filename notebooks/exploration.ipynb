#Load and inspect the data
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

df = pd.read_csv(r'D:\00_PortFolio\AI_ML\spam-classifier\data\spam.csv', encoding='latin-1')
df = df[['v1', 'v2']].rename(columns={'v1': 'label', 'v2': 'text'})

print(df.shape)           # (5572, 2)
print(df['label'].value_counts())
print(df.isnull().sum())  # check for missing values

#Visualize class distribution
# Class imbalance check — important!
df['label'].value_counts().plot(kind='bar', color=['#5DCAA5', '#D85A30'])
plt.title('Spam vs Ham distribution')
plt.xticks(rotation=0)
import os
os.makedirs('assets', exist_ok=True)  # creates folder if it doesn't exist
plt.savefig('assets/class_dist.png')  # save for README
plt.show()

#Analyse text length patterns
df['length'] = df['text'].apply(len)
df['word_count'] = df['text'].apply(lambda x: len(x.split()))

# Spam messages tend to be longer — prove it!
df.groupby('label')[['length', 'word_count']].mean()

